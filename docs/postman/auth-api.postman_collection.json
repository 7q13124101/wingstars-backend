{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-4a7b-8c9d-0e1f2a3b4c5d",
    "name": "Wingstars Auth & Account API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "superAdminToken",
      "value": ""
    },
    {
      "key": "accountId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Auth (Public)",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"johndoe\",\n  \"password\": \"password123\",\n  \"email\": \"john@example.com\",\n  \"fullName\": \"John Doe\",\n  \"phone\": \"0123456789\",\n  \"gender\": \"MALE\",\n  \"address\": \"123 Street, City\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"johndoe\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"your_refresh_token_here\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh-token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "refresh-token"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Account Management (Super Admin)",
      "item": [
        {
          "name": "Get All Accounts",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{superAdminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/accounts?page=0&size=10&sortBy=id&direction=desc&includeDeleted=true",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "accounts"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                },
                {
                  "key": "sortBy",
                  "value": "id"
                },
                {
                  "key": "direction",
                  "value": "desc"
                },
                {
                  "key": "includeDeleted",
                  "value": "true"
                }
              ]
            }
          }
        },
        {
          "name": "Get Account Detail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{superAdminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/accounts/{{accountId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "accounts",
                "{{accountId}}"
              ]
            }
          }
        },
        {
          "name": "Create Account (Internal)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{superAdminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin_user\",\n  \"password\": \"admin_password\",\n  \"email\": \"admin@wingstars.com\",\n  \"fullName\": \"System Admin\",\n  \"phone\": \"0987654321\",\n  \"gender\": \"FEMALE\",\n  \"address\": \"HQ Office\",\n  \"roleCode\": \"ADMIN\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/accounts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "accounts"
              ]
            }
          }
        },
        {
          "name": "Update Account",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{superAdminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"updated@example.com\",\n  \"fullName\": \"Updated Name\",\n  \"phone\": \"0111222333\",\n  \"gender\": \"OTHER\",\n  \"address\": \"New Address\",\n  \"roleCode\": \"USER\",\n  \"deleted\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/accounts/{{accountId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "accounts",
                "{{accountId}}"
              ]
            }
          }
        },
        {
          "name": "Lock Account",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{superAdminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/accounts/{{accountId}}/lock",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "accounts",
                "{{accountId}}",
                "lock"
              ]
            }
          }
        },
        {
          "name": "Unlock Account",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{superAdminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/accounts/{{accountId}}/unlock",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "accounts",
                "{{accountId}}",
                "unlock"
              ]
            }
          }
        }
      ]
    }
  ]
}
