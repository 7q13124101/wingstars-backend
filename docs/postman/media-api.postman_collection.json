{
  "info": {
    "_postman_id": "m1e2d3i4-a5s6-4s7e-8t9i-0o1n2c3o4l5l",
    "name": "Wingstars Media API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "fileId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Admin",
      "item": [
        {
          "name": "Upload File",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                },
                {
                  "key": "module_source",
                  "value": "BANNER_HOME",
                  "type": "text"
                },
                {
                  "key": "title",
                  "value": "My Upload",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/files/upload",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "files",
                "upload"
              ]
            }
          }
        },
        {
          "name": "Replace/Update File",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                },
                {
                  "key": "title",
                  "value": "Updated Title",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/files/{{fileId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "files",
                "{{fileId}}"
              ]
            }
          }
        },
        {
          "name": "Get Admin File List",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/files?page=0&size=10&moduleSource=BANNER_HOME",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "files"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                },
                {
                  "key": "moduleSource",
                  "value": "BANNER_HOME"
                }
              ]
            }
          }
        },
        {
          "name": "Delete File",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/files/{{fileId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "files",
                "{{fileId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Public",
      "item": [
        {
          "name": "Get Public File List",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/public/files?page=0&size=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "public",
                "files"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Public File Detail",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/public/files/{{fileId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "public",
                "files",
                "{{fileId}}"
              ]
            }
          }
        }
      ]
    }
  ]
}
